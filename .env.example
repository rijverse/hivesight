# Copy to .env and edit. .env is gitignored.

# Cowrie host ports. Defaults are the real SSH/Telnet ports (22/23), which is
# what a live honeypot wants. On a machine that already runs sshd, remap them
# so cowrie doesn't collide, e.g.:
#COWRIE_SSH_PORT=2222
#COWRIE_TELNET_PORT=2223

# Grafana admin password (defaults to "admin" if unset). Grafana is exposed on
# all interfaces (0.0.0.0:3000) and anonymous access is off, so the login form
# is the only way in. Set a strong password here, and firewall port 3000.
#GRAFANA_ADMIN_PASSWORD=change-me

# Grafana secret key, used to sign auth cookies and encrypt stored secrets.
# Optional but recommended once the dashboard is reachable off the box.
#GRAFANA_SECRET_KEY=

# Re-scan historical honeypot logs on orchestrator start (0 = no).
#ORCH_FORCE_BACKFILL=0

# Keep your own test traffic out of the honeypot stats. List one or more IPs
# you connect from, comma-separated with NO spaces (bin/up.sh sources this
# file, so an unquoted space would break it). Applied at ingest by both
# Promtail (Grafana dashboards) and the orchestrator (AI verdict panels).
# To use spaces for readability, quote the whole value.
#   EXCLUDE_IPS=203.0.113.7,198.51.100.4
#   EXCLUDE_IPS="203.0.113.7, 198.51.100.4"
#EXCLUDE_IPS=
#
# Advanced: a raw anchored regex instead of the list above (takes precedence
# when set). Quote it, and anchor with ^...$ so a short IP can't match a longer.
#   EXCLUDE_IP_REGEX="^(203\.0\.113\.7|198\.51\.100\.4)$"
#EXCLUDE_IP_REGEX=
