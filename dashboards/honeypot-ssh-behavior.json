    {
      "type": "table",
      "title": "Login Attempts Breakdown (selected range)",
      "description": "Per-source login counts and the failed-to-success ratio over the selected time range. Failed count is high while AuthRandom is freshly seeded; once attackers get cached, success count climbs and the ratio trends higher than the 3-5 initial random attempts.",
      "id": 70,
      "gridPos": {
        "x": 0,
        "y": 2,
        "w": 12,
        "h": 5
      },
      "datasource": {
        "type": "loki",
        "uid": "bfrvx638cgpa8d"
      },
      "targets": [
        {
          "refId": "F",
          "expr": "sum(count_over_time({job=\"cowrie\", eventid=\"cowrie.login.failed\"}[$__range]))",
          "queryType": "instant",
          "instant": true,
          "datasource": {
            "type": "loki",
            "uid": "bfrvx638cgpa8d"
          },
          "legendFormat": "Failed logins"
        },
        {
          "refId": "S",
          "expr": "sum(count_over_time({job=\"cowrie\", eventid=\"cowrie.login.success\"}[$__range]))",
          "queryType": "instant",
          "instant": true,
          "datasource": {
            "type": "loki",
            "uid": "bfrvx638cgpa8d"
          },
          "legendFormat": "Successful logins"
        },
        {
          "refId": "R",
          "expr": "(sum(count_over_time({job=\"cowrie\", eventid=\"cowrie.login.failed\"}[$__range]))) / (sum(count_over_time({job=\"cowrie\", eventid=\"cowrie.login.success\"}[$__range])))",
